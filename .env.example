SUPABASE_URL=https://your-project-ref.supabase.co
# Project Settings > API Keys in the Supabase dashboard. Newer projects call this
# the "publishable key" (sb_publishable_...); older projects call it "anon public" - both work here.
SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
# Settings > Projects > (your project) > Client Keys (DSN) in the Sentry dashboard.
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
