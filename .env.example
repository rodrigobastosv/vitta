SUPABASE_URL=https://your-project-ref.supabase.co
# Project Settings > API Keys in the Supabase dashboard. Newer projects call this
# the "publishable key" (sb_publishable_...); older projects call it "anon public" - both work here.
SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
# Settings > Projects > (your project) > Client Keys (DSN) in the Sentry dashboard.
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# RevenueCat public SDK keys: app.revenuecat.com > your project > API keys.
# Public by design - they ship inside the app binary and are not credentials.
# One key PER STORE, and they are not interchangeable: the key identifies which
# RevenueCat app you are, so an Android build configured with the appl_ key asks
# Play for App Store product ids and finds nothing (see docs/premium-setup.md).
# Either may be left empty - that platform then simply has no purchasable offer.
REVENUECAT_IOS_API_KEY=appl_your-public-ios-sdk-key
REVENUECAT_ANDROID_API_KEY=goog_your-public-android-sdk-key

# Google Analytics (for Firebase). Read out of google-services.json /
# GoogleService-Info.plist - see docs/analytics-setup.md. Not secrets: they ship
# inside the binary. Project id and sender id are shared by both stores; the API
# key and app id are per store and NOT interchangeable, same trap as the
# RevenueCat keys above. Leave any empty and that build simply reports nothing.
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_MESSAGING_SENDER_ID=1234567890
FIREBASE_ANDROID_API_KEY=your-android-api-key
FIREBASE_ANDROID_APP_ID=1:1234567890:android:abc123def456
FIREBASE_IOS_API_KEY=your-ios-api-key
FIREBASE_IOS_APP_ID=1:1234567890:ios:abc123def456
